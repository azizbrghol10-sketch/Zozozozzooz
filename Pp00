<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>تطبيق الأذان والمنبه والقبلة</title>
<style>
  :root{
    --bg-deep:#0d1b17;
    --bg-panel:#132922;
    --gold:#c9a24b;
    --gold-soft:#e3c878;
    --teal:#1f4d3f;
    --teal-light:#2c6b56;
    --text:#f2ead9;
    --text-dim:#a9b9b1;
    --danger:#b5533c;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    background: radial-gradient(circle at 50% -10%, #17332b 0%, var(--bg-deep) 60%);
    color:var(--text);
    font-family: 'Tahoma', 'Segoe UI', sans-serif;
    min-height:100vh;
    padding-bottom:40px;
  }
  .pattern-bar{
    height:10px;
    background: repeating-linear-gradient(45deg, var(--gold) 0 8px, transparent 8px 16px);
    opacity:0.55;
  }
  header{
    text-align:center;
    padding:22px 16px 10px;
  }
  header h1{
    font-size:1.5rem;
    color:var(--gold-soft);
    letter-spacing:1px;
  }
  header p{color:var(--text-dim); font-size:0.85rem; margin-top:4px;}

  nav.tabs{
    display:flex;
    justify-content:center;
    gap:6px;
    flex-wrap:wrap;
    margin:14px auto 20px;
    padding:0 12px;
  }
  nav.tabs button{
    background:var(--bg-panel);
    border:1px solid var(--teal-light);
    color:var(--text-dim);
    padding:9px 16px;
    border-radius:20px;
    font-size:0.85rem;
    cursor:pointer;
    transition:.2s;
  }
  nav.tabs button.active{
    background:var(--gold);
    color:#1a1a1a;
    border-color:var(--gold);
    font-weight:bold;
  }

  main{max-width:520px; margin:0 auto; padding:0 16px;}
  section{display:none;}
  section.active{display:block; animation: fadeIn .3s ease;}
  @keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  .card{
    background:var(--bg-panel);
    border:1px solid var(--teal-light);
    border-radius:16px;
    padding:20px;
    margin-bottom:16px;
    box-shadow:0 4px 18px rgba(0,0,0,.3);
  }

  /* الساعة */
  .clock-face{
    text-align:center;
    padding:30px 0 10px;
  }
  .clock-time{
    font-size:3.2rem;
    color:var(--gold-soft);
    font-weight:bold;
    letter-spacing:2px;
    direction:ltr;
  }
  .clock-date{color:var(--text-dim); margin-top:8px; font-size:1rem;}
  .next-prayer{
    margin-top:18px;
    background:var(--teal);
    border-radius:12px;
    padding:14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .next-prayer .label{color:var(--text-dim); font-size:.8rem;}
  .next-prayer .name{color:var(--gold-soft); font-size:1.2rem; font-weight:bold;}
  .next-prayer .countdown{font-size:1.3rem; direction:ltr;}

  /* أوقات الصلاة */
  .loc-row{display:flex; gap:8px; margin-bottom:14px;}
  .loc-row button{
    flex:1;
    background:var(--teal);
    color:var(--text);
    border:none;
    border-radius:10px;
    padding:10px;
    cursor:pointer;
    font-size:.9rem;
  }
  .loc-status{font-size:.8rem; color:var(--text-dim); text-align:center; margin-bottom:10px;}
  .prayer-list{list-style:none;}
  .prayer-list li{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:12px 4px;
    border-bottom:1px solid rgba(255,255,255,.06);
  }
  .prayer-list li:last-child{border-bottom:none;}
  .prayer-list .pname{font-weight:bold; color:var(--gold-soft);}
  .prayer-list .ptime{direction:ltr; font-size:1.05rem;}
  .toggle{
    width:42px; height:24px;
    background:#3a3a3a;
    border-radius:20px;
    position:relative;
    cursor:pointer;
    transition:.2s;
    flex-shrink:0;
  }
  .toggle.on{background:var(--gold);}
  .toggle::after{
    content:'';
    position:absolute;
    top:2px; right:2px;
    width:20px; height:20px;
    background:#fff;
    border-radius:50%;
    transition:.2s;
  }
  .toggle.on::after{right:20px;}
  .prayer-row-controls{display:flex; align-items:center; gap:14px;}

  /* المنبه */
  .alarm-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:var(--teal);
    border-radius:12px;
    padding:14px;
    margin-bottom:10px;
  }
  .alarm-item .time{font-size:1.6rem; direction:ltr; color:var(--gold-soft);}
  .alarm-item .meta{font-size:.75rem; color:var(--text-dim);}
  .alarm-item button.del{
    background:none; border:none; color:var(--danger); font-size:1.2rem; cursor:pointer;
  }
  .new-alarm-form{display:flex; flex-direction:column; gap:10px; margin-top:8px;}
  .new-alarm-form input[type=time]{
    background:var(--bg-deep); color:var(--text); border:1px solid var(--teal-light);
    border-radius:8px; padding:8px; font-size:1rem; direction:ltr;
  }
  .new-alarm-form select{
    background:var(--bg-deep); color:var(--text); border:1px solid var(--teal-light);
    border-radius:8px; padding:8px; font-size:.9rem;
  }
  .btn-primary{
    background:var(--gold); color:#1a1a1a; border:none; border-radius:10px;
    padding:11px; font-weight:bold; cursor:pointer; font-size:.95rem;
  }
  .btn-secondary{
    background:transparent; color:var(--gold-soft); border:1px solid var(--gold); border-radius:10px;
    padding:10px; cursor:pointer; font-size:.85rem;
  }

  /* الصوت */
  .sound-option{
    display:flex; justify-content:space-between; align-items:center;
    padding:10px 4px; border-bottom:1px solid rgba(255,255,255,.06);
  }
  input[type=file]{color:var(--text-dim); font-size:.75rem; max-width:150px;}

  /* القبلة */
  .compass-wrap{display:flex; flex-direction:column; align-items:center; padding:10px 0 6px;}
  .compass{
    width:220px; height:220px;
    border-radius:50%;
    border:3px solid var(--gold);
    position:relative;
    background:
      radial-gradient(circle, rgba(201,162,75,.06) 0%, transparent 70%),
      var(--bg-deep);
    margin:10px 0 20px;
  }
  .compass::before, .compass::after{
    content:'';
    position:absolute;
    background:rgba(255,255,255,.15);
  }
  .compass::before{width:1px; height:100%; right:50%;}
  .compass::after{height:1px; width:100%; top:50%;}
  .needle{
    position:absolute;
    left:50%; top:50%;
    width:4px; height:90px;
    background:linear-gradient(to top, var(--danger), var(--gold-soft));
    transform-origin:bottom center;
    transform:translate(-50%,-100%) rotate(0deg);
    border-radius:4px;
    transition:transform .25s ease-out;
  }
  .kaaba-icon{
    position:absolute; top:-30px; left:50%;
    transform:translateX(-50%);
    font-size:1.4rem;
  }
  .compass-dir{position:absolute; color:var(--text-dim); font-size:.85rem;}
  .n{top:6px; left:50%; transform:translateX(-50%);}
  .s{bottom:6px; left:50%; transform:translateX(-50%);}
  .e{top:50%; right:6px; transform:translateY(-50%);}
  .w{top:50%; left:6px; transform:translateY(-50%);}
  .qibla-info{text-align:center; color:var(--text-dim); font-size:.9rem; line-height:1.7;}
  .qibla-info b{color:var(--gold-soft);}

  .stop-alarm-overlay{
    position:fixed; inset:0; background:rgba(0,0,0,.85);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    z-index:999; gap:20px; text-align:center; padding:20px;
  }
  .stop-alarm-overlay h2{color:var(--gold-soft); font-size:1.6rem;}
  .stop-alarm-overlay .big-time{font-size:2.4rem; direction:ltr;}
  .stop-btn{
    background:var(--danger); color:#fff; border:none; border-radius:14px;
    padding:16px 40px; font-size:1.1rem; font-weight:bold; cursor:pointer;
  }
  .hint{font-size:.75rem; color:var(--text-dim); margin-top:6px;}
</style>
</head>
<body>

<div class="pattern-bar"></div>
<header>
  <h1>🕌 رفيق الصلاة</h1>
  <p>الساعة · الأذان · المنبه · اتجاه القبلة</p>
</header>

<nav class="tabs">
  <button data-tab="clock" class="active">الساعة</button>
  <button data-tab="prayers">أوقات الصلاة</button>
  <button data-tab="alarms">المنبه</button>
  <button data-tab="qibla">القبلة</button>
  <button data-tab="sound">الصوت</button>
</nav>

<main>

  <!-- الساعة -->
  <section id="clock" class="active">
    <div class="card clock-face">
      <div class="clock-time" id="clockTime">--:--:--</div>
      <div class="clock-date" id="clockDate">—</div>
      <div class="next-prayer">
        <div>
          <div class="label">الصلاة القادمة</div>
          <div class="name" id="nextPrayerName">—</div>
        </div>
        <div class="countdown" id="nextPrayerCountdown">--:--:--</div>
      </div>
    </div>
  </section>

  <!-- أوقات الصلاة -->
  <section id="prayers">
    <div class="card">
      <div class="loc-row">
        <button id="getLocationBtn">📍 تحديد موقعي تلقائيًا</button>
      </div>
      <div class="loc-status" id="locStatus">لم يتم تحديد الموقع بعد — سيتم استخدام مكة المكرمة مؤقتًا</div>
      <ul class="prayer-list" id="prayerList"></ul>
    </div>
    <div class="card">
      <div class="loc-status" style="margin-bottom:0;">فعّل مفتاح أي صلاة ليتم تشغيل الأذان تلقائيًا في وقتها</div>
    </div>
  </section>

  <!-- المنبه -->
  <section id="alarms">
    <div class="card">
      <div id="alarmsListContainer"></div>
      <div class="new-alarm-form">
        <input type="time" id="newAlarmTime">
        <select id="newAlarmSound">
          <option value="default">النغمة الافتراضية</option>
          <option value="azan">صوت الأذان</option>
        </select>
        <button class="btn-primary" id="addAlarmBtn">إضافة منبه</button>
      </div>
    </div>
  </section>

  <!-- القبلة -->
  <section id="qibla">
    <div class="card compass-wrap">
      <div class="compass" id="compass">
        <span class="kaaba-icon">🕋</span>
        <div class="needle" id="needle"></div>
        <span class="compass-dir n">ش</span>
        <span class="compass-dir s">ج</span>
        <span class="compass-dir e">ق</span>
        <span class="compass-dir w">غ</span>
      </div>
      <div class="qibla-info" id="qiblaInfo">
        اضغط "تفعيل البوصلة" ثم وجّه هاتفك أفقيًا — السهم الذهبي يشير لاتجاه الكعبة 🕋
      </div>
      <div style="margin-top:14px; display:flex; gap:10px;">
        <button class="btn-primary" id="enableCompassBtn">تفعيل البوصلة</button>
        <button class="btn-secondary" id="refreshLocBtn">تحديث الموقع</button>
      </div>
    </div>
  </section>

  <!-- الصوت -->
  <section id="sound">
    <div class="card">
      <p style="color:var(--text-dim); font-size:.85rem; margin-bottom:10px;">
        يعمل التطبيق بنغمة أذان افتراضية مُولّدة إلكترونيًا. يمكنك استبدالها بأي تسجيل صوتي تختاره (مثل صوت شيخ معيّن) من ملفاتك.
      </p>
      <div class="sound-option">
        <span>نغمة الأذان الحالية</span>
        <span id="azanSoundLabel" style="color:var(--gold-soft);">الافتراضية</span>
      </div>
      <div class="sound-option">
        <span>رفع ملف أذان مخصص (MP3)</span>
        <input type="file" id="azanFileInput" accept="audio/*">
      </div>
      <div class="sound-option">
        <span>تجربة الصوت</span>
        <button class="btn-secondary" id="previewAzanBtn">▶ تشغيل</button>
      </div>
      <div class="sound-option" style="border-bottom:none;">
        <span>إعادة الضبط للنغمة الافتراضية</span>
        <button class="btn-secondary" id="resetAzanBtn">إعادة</button>
      </div>
      <p class="hint">ملاحظة: الملف المرفوع يبقى محفوظًا خلال هذه الجلسة فقط داخل المتصفح.</p>
    </div>
  </section>

</main>

<script>
/* ======================= الحالة العامة ======================= */
const state = {
  lat: 21.4225, lon: 39.8262, tzOffsetHours: -(new Date().getTimezoneOffset()/60), // ساعات محلية
  locationKnown:false,
  prayerEnabled: {fajr:true, dhuhr:true, asr:true, maghrib:true, isha:true},
  alarms: [], // {id, time:'HH:MM', sound:'default'|'azan'}
  customAzanURL: null,
  activeAudio:null,
};

/* ======================= التبويبات ======================= */
document.querySelectorAll('nav.tabs button').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('main section').forEach(s=>s.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(btn.dataset.tab).classList.add('active');
  });
});

/* ======================= الساعة والتاريخ ======================= */
function pad(n){return n.toString().padStart(2,'0');}

function updateClock(){
  const now = new Date();
  document.getElementById('clockTime').textContent =
    `${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
  const days=['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
  const months=['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
  document.getElementById('clockDate').textContent =
    `${days[now.getDay()]}، ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
  checkAlarms(now);
  updateNextPrayer(now);
}
setInterval(updateClock, 1000);

/* ======================= حساب أوقات الصلاة ======================= */
// خوارزمية فلكية قياسية (معادلة الزمن وميل الشمس) لحساب أوقات الصلاة
function julianDate(date){
  let y=date.getUTCFullYear(), m=date.getUTCMonth()+1, d=date.getUTCDate();
  if(m<=2){y-=1; m+=12;}
  const A=Math.floor(y/100), B=2-A+Math.floor(A/4);
  return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+B-1524.5;
}
const dtr=d=>d*Math.PI/180, rtd=r=>r*180/Math.PI;
function fixAngle(a){a=a%360; return a<0?a+360:a;}
function fixHour(h){h=h%24; return h<0?h+24:h;}

function sunPosition(jd){
  const D = jd - 2451545.0;
  const g = fixAngle(357.529 + 0.98560028*D);
  const q = fixAngle(280.459 + 0.98564736*D);
  const L = fixAngle(q + 1.915*Math.sin(dtr(g)) + 0.020*Math.sin(dtr(2*g)));
  const e = 23.439 - 0.00000036*D;
  let RA = rtd(Math.atan2(Math.cos(dtr(e))*Math.sin(dtr(L)), Math.cos(dtr(L))))/15;
  RA = fixHour(RA);
  const eqt = q/15 - RA;
  const decl = rtd(Math.asin(Math.sin(dtr(e))*Math.sin(dtr(L))));
  return {decl, eqt};
}

function computeTimeForAngle(angle, jd, lat, lon, tz, isAfter){
  // إيجاد الوقت الذي تصل فيه الشمس لزاوية ارتفاع معينة تحت/فوق الأفق
  let t = 12;
  for(let i=0;i<2;i++){
    const {decl, eqt} = sunPosition(jd + (t/24));
    const noon = fixHour(12 - lon/15 - eqt) ;
    const cosArg = (-Math.sin(dtr(angle)) - Math.sin(dtr(lat))*Math.sin(dtr(decl))) /
                    (Math.cos(dtr(lat))*Math.cos(dtr(decl)));
    if(cosArg>1||cosArg<-1) return null;
    const T = rtd(Math.acos(cosArg))/15;
    t = isAfter ? noon + T : noon - T;
  }
  return fixHour(t + tz - lon/15);
}

function computeDhuhr(jd, lon, tz){
  const {eqt} = sunPosition(jd);
  return fixHour(12 - lon/15 - eqt + tz - lon/15 + lon/15); // مبسّطة أدناه
}

function computeAsr(jd, lat, tz, lon){
  const {decl} = sunPosition(jd);
  const factor = 1; // الشافعي
  const angle = -rtd(Math.atan(1/(factor+Math.tan(dtr(Math.abs(lat-decl))))));
  return computeTimeForAngle(angle, jd, lat, lon, tz, true);
}

function getPrayerTimes(date, lat, lon, tzHours){
  const jd = julianDate(date);
  const {eqt} = sunPosition(jd);
  const dhuhr = fixHour(12 + tzHours - lon/15 - eqt);
  const fajr = computeTimeForAngle(18, jd, lat, lon, tzHours, false);
  const sunrise = computeTimeForAngle(0.833, jd, lat, lon, tzHours, false);
  const maghrib = computeTimeForAngle(0.833, jd, lat, lon, tzHours, true);
  const isha = computeTimeForAngle(17, jd, lat, lon, tzHours, true);
  const asr = computeAsr(jd, lat, tzHours, lon);
  return {fajr, sunrise, dhuhr, asr, maghrib, isha};
}

function hoursToHHMM(h){
  if(h===null||isNaN(h)) return '—';
  h = fixHour(h);
  const hh = Math.floor(h);
  const mm = Math.round((h-hh)*60);
  return `${pad(hh)}:${pad(mm===60?0:mm)}`;
}

const prayerNamesAr = {fajr:'الفجر', sunrise:'الشروق', dhuhr:'الظهر', asr:'العصر', maghrib:'المغرب', isha:'العشاء'};
let todayTimes = {};

function renderPrayerList(){
  todayTimes = getPrayerTimes(new Date(), state.lat, state.lon, state.tzOffsetHours);
  const list = document.getElementById('prayerList');
  list.innerHTML='';
  Object.keys(prayerNamesAr).forEach(key=>{
    const li = document.createElement('li');
    const timeStr = hoursToHHMM(todayTimes[key]);
    let controls = `<span class="ptime">${timeStr}</span>`;
    if(key!=='sunrise'){
      const on = state.prayerEnabled[key];
      controls = `<div class="prayer-row-controls">
                    <span class="ptime">${timeStr}</span>
                    <div class="toggle ${on?'on':''}" data-prayer="${key}"></div>
                  </div>`;
    }
    li.innerHTML = `<span class="pname">${prayerNamesAr[key]}</span>${controls}`;
    list.appendChild(li);
  });
  document.querySelectorAll('.toggle').forEach(t=>{
    t.addEventListener('click', ()=>{
      const p = t.dataset.prayer;
      state.prayerEnabled[p] = !state.prayerEnabled[p];
      t.classList.toggle('on');
    });
  });
}

function updateNextPrayer(now){
  if(!todayTimes.fajr) return;
  const order = ['fajr','dhuhr','asr','maghrib','isha'];
  const nowH = now.getHours() + now.getMinutes()/60 + now.getSeconds()/3600;
  let next=null, nextH=null;
  for(const key of order){
    if(todayTimes[key]>nowH){ next=key; nextH=todayTimes[key]; break; }
  }
  if(!next){ next='fajr'; nextH = todayTimes.fajr + 24; }
  const diff = nextH - nowH;
  const dH = Math.floor(diff);
  const dM = Math.floor((diff-dH)*60);
  const dS = Math.floor((((diff-dH)*60)-dM)*60);
  document.getElementById('nextPrayerName').textContent = prayerNamesAr[next];
  document.getElementById('nextPrayerCountdown').textContent = `${pad(dH)}:${pad(dM)}:${pad(dS)}`;
}

/* تتبع دقيقة تغيّرت فيها الصلاة لتشغيل الأذان مرة واحدة فقط */
let lastCheckedMinute = null;
function checkPrayerAzan(now){
  const hh = now.getHours(), mm = now.getMinutes();
  const key = `${hh}:${mm}`;
  if(key===lastCheckedMinute) return;
  lastCheckedMinute = key;
  const nowH = hh + mm/60;
  Object.keys(prayerNamesAr).forEach(pk=>{
    if(pk==='sunrise') return;
    if(!state.prayerEnabled[pk]) return;
    const pH = todayTimes[pk];
    if(pH!==null && Math.round(pH*60)===Math.round(nowH*60)){
      triggerAzan(prayerNamesAr[pk]);
    }
  });
}

document.getElementById('getLocationBtn').addEventListener('click', ()=>{
  const statusEl = document.getElementById('locStatus');
  statusEl.textContent = 'جارٍ تحديد الموقع...';
  if(!navigator.geolocation){
    statusEl.textContent = 'المتصفح لا يدعم تحديد الموقع';
    return;
  }
  navigator.geolocation.getCurrentPosition(pos=>{
    state.lat = pos.coords.latitude;
    state.lon = pos.coords.longitude;
    state.locationKnown = true;
    statusEl.textContent = `تم تحديد الموقع (${state.lat.toFixed(2)}, ${state.lon.toFixed(2)})`;
    renderPrayerList();
    updateQiblaAngle();
  }, err=>{
    statusEl.textContent = 'تعذّر الوصول للموقع — تأكد من إذن الموقع في المتصفح';
  });
});

/* ======================= الصوت: توليد الأذان الافتراضي + رفع ملف ======================= */
let audioCtx = null;
function getCtx(){
  if(!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  return audioCtx;
}

// نغمة افتراضية مُولّدة (لحن جرسي هادئ يُستخدم كتنبيه، وليس تلاوة فعلية)
function playDefaultTone(loop, durationSeconds=8){
  const ctx = getCtx();
  const notes = [523.25, 659.25, 783.99, 659.25, 523.25, 392.00];
  let time = ctx.currentTime;
  const gainMaster = ctx.createGain();
  gainMaster.gain.value = 0.25;
  gainMaster.connect(ctx.destination);

  function scheduleOnce(startTime){
    notes.forEach((freq,i)=>{
      const osc = ctx.createOscillator();
      const g = ctx.createGain();
      osc.type='sine';
      osc.frequency.value = freq;
      const t0 = startTime + i*0.5;
      g.gain.setValueAtTime(0, t0);
      g.gain.linearRampToValueAtTime(0.9, t0+0.05);
      g.gain.linearRampToValueAtTime(0, t0+0.45);
      osc.connect(g); g.connect(gainMaster);
      osc.start(t0); osc.stop(t0+0.5);
    });
  }
  const cycles = loop ? Math.ceil(durationSeconds/(notes.length*0.5)) : 1;
  for(let c=0;c<cycles;c++){
    scheduleOnce(time + c*notes.length*0.5);
  }
  state.activeAudio = {type:'synth', stop:()=>{ try{ctx.close();}catch(e){} audioCtx=null; }};
}

document.getElementById('azanFileInput').addEventListener('change', (e)=>{
  const file = e.target.files[0];
  if(!file) return;
  if(state.customAzanURL) URL.revokeObjectURL(state.customAzanURL);
  state.customAzanURL = URL.createObjectURL(file);
  document.getElementById('azanSoundLabel').textContent = file.name;
});

document.getElementById('resetAzanBtn').addEventListener('click', ()=>{
  if(state.customAzanURL) URL.revokeObjectURL(state.customAzanURL);
  state.customAzanURL = null;
  document.getElementById('azanFileInput').value='';
  document.getElementById('azanSoundLabel').textContent = 'الافتراضية';
});

document.getElementById('previewAzanBtn').addEventListener('click', ()=>{
  playAzanSound(false);
});

function playAzanSound(loop){
  if(state.customAzanURL){
    const audio = new Audio(state.customAzanURL);
    audio.loop = loop;
    audio.play().catch(()=>{});
    state.activeAudio = {type:'file', el:audio, stop:()=>{audio.pause(); audio.currentTime=0;}};
  } else {
    playDefaultTone(loop, loop?300:8);
  }
}

function stopActiveAudio(){
  if(state.activeAudio && state.activeAudio.stop){ state.activeAudio.stop(); }
  state.activeAudio = null;
}

/* ======================= المنبه ======================= */
function renderAlarms(){
  const container = document.getElementById('alarmsListContainer');
  container.innerHTML='';
  if(state.alarms.length===0){
    container.innerHTML = `<p class="hint" style="text-align:center; margin-bottom:10px;">لا توجد منبهات بعد</p>`;
  }
  state.alarms.forEach(a=>{
    const div = document.createElement('div');
    div.className='alarm-item';
    div.innerHTML = `
      <div>
        <div class="time">${a.time}</div>
        <div class="meta">${a.sound==='azan' ? 'صوت الأذان' : 'النغمة الافتراضية'}</div>
      </div>
      <button class="del" data-id="${a.id}">✕</button>`;
    container.appendChild(div);
  });
  container.querySelectorAll('.del').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      state.alarms = state.alarms.filter(a=>a.id!==btn.dataset.id);
      renderAlarms();
    });
  });
}

document.getElementById('addAlarmBtn').addEventListener('click', ()=>{
  const timeVal = document.getElementById('newAlarmTime').value;
  if(!timeVal) return;
  const sound = document.getElementById('newAlarmSound').value;
  state.alarms.push({id:Date.now().toString(), time:timeVal, sound});
  renderAlarms();
});

let alarmLastMinute = null;
function checkAlarms(now){
  const hh=pad(now.getHours()), mm=pad(now.getMinutes());
  const cur = `${hh}:${mm}`;
  checkPrayerAzan(now);
  if(cur===alarmLastMinute) return;
  alarmLastMinute = cur;
  state.alarms.forEach(a=>{
    if(a.time===cur){
      showAlarmOverlay(a);
    }
  });
}

function showAlarmOverlay(alarm){
  const overlay = document.createElement('div');
  overlay.className='stop-alarm-overlay';
  overlay.innerHTML = `
    <div style="font-size:2.6rem;">⏰</div>
    <h2>حان وقت المنبه</h2>
    <div class="big-time">${alarm.time}</div>
    <button class="stop-btn" id="stopAlarmBtn">إيقاف</button>`;
  document.body.appendChild(overlay);
  if(navigator.vibrate) navigator.vibrate([500,200,500,200,500]);
  if(alarm.sound==='azan'){ playAzanSound(true); }
  else { playDefaultTone(true, 300); }
  document.getElementById('stopAlarmBtn').addEventListener('click', ()=>{
    stopActiveAudio();
    if(navigator.vibrate) navigator.vibrate(0);
    overlay.remove();
  });
}

function triggerAzan(prayerName){
  const overlay = document.createElement('div');
  overlay.className='stop-alarm-overlay';
  overlay.innerHTML = `
    <div style="font-size:2.6rem;">🕌</div>
    <h2>حان وقت صلاة ${prayerName}</h2>
    <button class="stop-btn" id="stopAzanBtn">إيقاف الأذان</button>`;
  document.body.appendChild(overlay);
  if(navigator.vibrate) navigator.vibrate([400,150,400]);
  playAzanSound(true);
  document.getElementById('stopAzanBtn').addEventListener('click', ()=>{
    stopActiveAudio();
    overlay.remove();
  });
}

/* ======================= القبلة ======================= */
function qiblaBearing(lat, lon){
  const kLat = dtr(21.4225), kLon = dtr(39.8262);
  const phi = dtr(lat), lam = dtr(lon);
  const dLon = kLon - lam;
  const y = Math.sin(dLon)*Math.cos(kLat);
  const x = Math.cos(phi)*Math.sin(kLat) - Math.sin(phi)*Math.cos(kLat)*Math.cos(dLon);
  return fixAngle(rtd(Math.atan2(y,x)));
}

let qiblaAngle = 0;
let deviceHeading = 0;

function updateQiblaAngle(){
  qiblaAngle = qiblaBearing(state.lat, state.lon);
  document.getElementById('qiblaInfo').innerHTML =
    `اتجاه القبلة من موقعك: <b>${qiblaAngle.toFixed(1)}°</b> من الشمال<br>وجّه هاتفك أفقيًا لمتابعة السهم`;
  applyNeedleRotation();
}

function applyNeedleRotation(){
  const rotation = fixAngle(qiblaAngle - deviceHeading);
  document.getElementById('needle').style.transform = `translate(-50%,-100%) rotate(${rotation}deg)`;
}

function handleOrientation(e){
  let heading;
  if(typeof e.webkitCompassHeading === 'number'){
    heading = e.webkitCompassHeading; // iOS
  } else if(e.alpha !== null){
    heading = 360 - e.alpha; // تقريب لأندرويد
  } else {
    return;
  }
  deviceHeading = fixAngle(heading);
  applyNeedleRotation();
}

document.getElementById('enableCompassBtn').addEventListener('click', async ()=>{
  updateQiblaAngle();
  if(typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function'){
    try{
      const res = await DeviceOrientationEvent.requestPermission();
      if(res==='granted'){
        window.addEventListener('deviceorientation', handleOrientation, true);
      } else {
        document.getElementById('qiblaInfo').textContent = 'تم رفض إذن البوصلة — يمكنك الاعتماد على زاوية القبلة الرقمية أعلاه.';
      }
    }catch(err){
      document.getElementById('qiblaInfo').textContent = 'تعذّر تفعيل حساسات الاتجاه على هذا الجهاز.';
    }
  } else {
    window.addEventListener('deviceorientationabsolute', handleOrientation, true);
    window.addEventListener('deviceorientation', handleOrientation, true);
  }
});

document.getElementById('refreshLocBtn').addEventListener('click', ()=>{
  document.getElementById('getLocationBtn').click();
  setTimeout(updateQiblaAngle, 1200);
});

/* ======================= بدء التشغيل ======================= */
renderPrayerList();
renderAlarms();
updateQiblaAngle();
updateClock();
