            <div className="relative w-64 h-64 rounded-full flex items-center justify-center"
              style={{ background: "radial-gradient(circle,#FFF6E0,#E8C766)", border: "4px solid #3F4B23" }}>
              <div className="absolute inset-3 rounded-full" style={{ border: "1px dashed #4A5D23" }} />
              <span className="absolute top-2 text-xs font-bold" style={{ color: "#2A3318" }}>ش</span>
              <span className="absolute bottom-2 text-xs font-bold" style={{ color: "#2A3318" }}>ج</span>
              <span className="absolute right-2 text-xs font-bold" style={{ color: "#2A3318" }}>غ</span>
