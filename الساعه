/* ---------------- Main App ---------------- */
export default function App() {
  const [tab, setTab] = useState("home");
  const [now, setNow] = useState(new Date());
  const [location, setLocation] = useState({ lat: 24.7136, lng: 46.6753, city: "الرياض (افتراضي)" });
  const [timezone, setTimezone] = useState(-new Date().getTimezoneOffset() / 60);
  const [method, setMethod] = useState("MWL");
  const [asrFactor, setAsrFactor] = useState(1);
  const [offsets, setOffsets] = useState({ fajr: 0, sunrise: 0, dhuhr: 0, asr: 0, maghrib: 0, isha: 0 });
  const [locating, setLocating] = useState(false);
  const [heading, setHeading] = useState(null);
  const [compassPermission, setCompassPermission] = useState("unknown");
  const [tones, setTones] = useState([
    { id: "tone1", name: "نغمة 1", type: "builtin" },
    { id: "tone2", name: "نغمة 2", type: "builtin" },
    { id: "tone3", name: "نغمة 3", type: "builtin" },
  ]);
  const [alarms, setAlarms] = useState([]);
  const [prayerAlerts, setPrayerAlerts] = useState({ fajr: true, sunrise: false, dhuhr: true, asr: true, maghrib: true, isha: true });
  const [activeAdhanTone, setActiveAdhanTone] = useState("tone2");
  const [activeAlarmTone, setActiveAlarmTone] = useState("tone1");
  const [ringing, setRinging] = useState(null);
  const [showSettings, setShowSettings] = useState(false);
  const [newAlarmTime, setNewAlarmTime] = useState("06:00");
  const [newAlarmLabel, setNewAlarmLabel] = useState("");
  const [loaded, setLoaded] = useState(false);

  const lastTriggerRef = useRef({});
  const audioElRef = useRef(null);
  const ringToneCtxRef = useRef(null);

  /* clock tick */
  useEffect(() => {
    const t = setInterval(() => setNow(new Date()), 1000);
    return () => clearInterval(t);
  }, []);

  /* load persisted settings */
  useEffect(() => {
    (async () => {
      try {
        const res = await window.storage.get("prayer-app-settings");
        if (res && res.value) {
          const s = JSON.parse(res.value);
          if (s.location) setLocation(s.location);
          if (s.timezone !== undefined) setTimezone(s.timezone);
          if (s.method) setMethod(s.method);
          if (s.asrFactor) setAsrFactor(s.asrFactor);
          if (s.offsets) setOffsets(s.offsets);
          if (s.alarms) setAlarms(s.alarms);
          if (s.prayerAlerts) setPrayerAlerts(s.prayerAlerts);
          if (s.activeAdhanTone) setActiveAdhanTone(s.activeAdhanTone);
          if (s.activeAlarmTone) setActiveAlarmTone(s.activeAlarmTone);
        }
      } catch (e) { /* no saved settings yet */ }
      setLoaded(true);
    })();
  }, []);

  /* persist settings */
  useEffect(() => {
    if (!loaded) return;
    const s = { location, timezone, method, asrFactor, offsets, alarms, prayerAlerts, activeAdhanTone, activeAlarmTone };
    window.storage.set("prayer-app-settings", JSON.stringify(s)).catch(() => {});
  }, [loaded, location, timezone, method, asrFactor, offsets, alarms, prayerAlerts, activeAdhanTone, activeAlarmTone]);

  const times = computeTimes({ lat: location.lat, lng: location.lng, timezone, date: now, method, asrFactor, offsets });
  const qibla = qiblaBearing(location.lat, location.lng);

  /* check alarms / prayer alerts every second */
  useEffect(() => {
    const hhmm = now.toTimeString().slice(0, 5);
    const key = now.toDateString() + "_" + hhmm;

    alarms.forEach((a) => {
      if (a.enabled && a.time === hhmm && lastTriggerRef.current[a.id + hhmm] !== true) {
        lastTriggerRef.current[a.id + hhmm] = true;
        triggerRing(a.label || "تنبيه المنبه", a.tone || activeAlarmTone);
      }
    });

    PRAYERS.forEach((p) => {
      if (p.key === "sunrise") return;
      const t = times[p.key];
      if (!t) return;
      const th = t.toTimeString().slice(0, 5);
      if (prayerAlerts[p.key] && th === hhmm && lastTriggerRef.current["prayer_" + p.key + key] !== true) {
        lastTriggerRef.current["prayer_" + p.key + key] = true;
        triggerRing("حان الآن وقت أذان " + p.label, activeAdhanTone);
      }
    });
  }, [now]);

  const triggerRing = (label, toneId) => {
    setRinging({ label, toneId });
    playTone(toneId, 25000);
  };

  const playTone = (toneId, duration = 4000) => {
    const tone = tones.find((t) => t.id === toneId);
    if (!tone) return;
    if (tone.type === "builtin") {
      ringToneCtxRef.current = playBuiltInTone(toneId, duration);
    } else if (tone.type === "custom") {
      if (audioElRef.current) { audioElRef.current.pause(); }
      const audio = new Audio(tone.url);
      audio.loop = true;
      audio.play().catch(() => {});
      audioElRef.current = audio;
      setTimeout(() => { audio.pause(); }, duration);
    }
  };

  const stopRinging = () => {
    setRinging(null);
    if (audioElRef.current) { audioElRef.current.pause(); audioElRef.current = null; }
    if (ringToneCtxRef.current) { try { ringToneCtxRef.current.close(); } catch (e) {} }
  };

  const detectLocation = () => {
    setLocating(true);
    if (!navigator.geolocation) { setLocating(false); return; }
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        setLocation({ lat: pos.coords.latitude, lng: pos.coords.longitude, city: "موقعي الحالي" });
        setTimezone(-new Date().getTimezoneOffset() / 60);
        setLocating(false);
      },
      () => setLocating(false),
      { enableHighAccuracy: true, timeout: 8000 }
    );
  };

  /* compass */
  const enableCompass = async () => {
    if (typeof DeviceOrientationEvent !== "undefined" && typeof DeviceOrientationEvent.requestPermission === "function") {
      try {
        const perm = await DeviceOrientationEvent.requestPermission();
        setCompassPermission(perm);
        if (perm !== "granted") return;
      } catch (e) { setCompassPermission("denied"); return; }
    } else {
      setCompassPermission("granted");
    }
    window.addEventListener("deviceorientationabsolute", handleOrientation, true);
    window.addEventListener("deviceorientation", handleOrientation, true);
  };
  const handleOrientation = (e) => {
    let h = e.webkitCompassHeading != null ? e.webkitCompassHeading : (e.alpha != null ? 360 - e.alpha : null);
    if (h != null) setHeading(h);
  };
  useEffect(() => () => {
    window.removeEventListener("deviceorientationabsolute", handleOrientation, true);
    window.removeEventListener("deviceorientation", handleOrientation, true);
  }, []);

  const handleFileUpload = (e, purpose) => {
    const file = e.target.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const id = "custom_" + Date.now();
    const newTone = { id, name: file.name.replace(/\.[^/.]+$/, ""), type: "custom", url };
    setTones((prev) => [...prev, newTone]);
    if (purpose === "adhan") setActiveAdhanTone(id);
    else setActiveAlarmTone(id);
    e.target.value = "";
  };

  const addAlarm = () => {
    setAlarms((prev) => [...prev, { id: Date.now(), time: newAlarmTime, label: newAlarmLabel || "استيقظ", enabled: true, tone: activeAlarmTone }]);
    setNewAlarmLabel("");
  };
  const removeAlarm = (id) => setAlarms((prev) => prev.filter((a) => a.id !== id));
  const toggleAlarm = (id) => setAlarms((prev) => prev.map((a) => a.id === id ? { ...a, enabled: !a.enabled } : a));

  const nextPrayer = (() => {
    const list = PRAYERS.filter((p) => p.key !== "sunrise" && times[p.key]);
    const upcoming = list.find((p) => times[p.key] > now);
    return upcoming || list[0];
  })();

  const compassRotation = heading != null ? qibla - heading : qibla;

  return (
    <div dir="rtl" className="min-h-screen w-full" style={{
      background: "radial-gradient(ellipse at top, #E3B94A 0%, #C79A2E 35%, #8B6914 75%, #5C4410 100%)",
      fontFamily: "'Tajawal','Segoe UI',sans-serif",
    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Tajawal:wght@300;400;500;700&display=swap');
        .amiri { font-family: 'Amiri', serif; }
        .islamic-pattern {
          background-image: radial-gradient(circle, rgba(255,246,224,0.10) 1px, transparent 1px);
          background-size: 22px 22px;
        }
      `}</style>

      <div className="max-w-md mx-auto min-h-screen relative islamic-pattern">
        {/* Header */}
        <div className="px-5 pt-6 pb-2 text-center relative">
          <div className="flex justify-center mb-1">
            <Moon className="w-6 h-6" style={{ color: "#3F4B23" }} />
          </div>
          <h1 className="amiri text-3xl font-bold" style={{ color: "#2A3318" }}>مواقيت الصلاة</h1>
          <p className="text-xs mt-1" style={{ color: "#4A3E10" }}>{location.city} · {location.lat.toFixed(2)}°, {location.lng.toFixed(2)}°</p>
        </div>

        <MosqueSkyline />

        {/* Clock */}
        <div className="mx-5 -mt-3 rounded-2xl p-5 shadow-lg text-center" style={{ background: "linear-gradient(135deg,#4A5D23,#2A3318)", border: "1px solid #E8C766" }}>
          <div className="amiri text-5xl font-bold tracking-wide" style={{ color: "#FFF6E0" }}>
            {now.toLocaleTimeString("ar-SA", { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: true })}
          </div>
          <div className="text-sm mt-1" style={{ color: "#E8C766" }}>
            {now.toLocaleDateString("ar-SA", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}
          </div>
          {nextPrayer && (
            <div className="mt-3 pt-3 flex items-center justify-center gap-2 text-sm" style={{ borderTop: "1px solid rgba(232,199,102,0.3)", color: "#FFF6E0" }}>
              <Bell className="w-4 h-4" style={{ color: "#E8C766" }} />
              <span>القادمة: {nextPrayer.label} — {fmtTime(times[nextPrayer.key])}</span>
            </div>
          )}
        </div>

        {/* Tabs */}
        <div className="flex mx-5 mt-5 rounded-xl overflow-hidden" style={{ border: "1px solid #4A5D23" }}>
          {[
            { id: "home", label: "المواقيت", icon: Clock },
            { id: "qibla", label: "القبلة", icon: Compass },
            { id: "alarms", label: "المنبه", icon: Bell },
          ].map((t) => (
            <button key={t.id} onClick={() => setTab(t.id)}
              className="flex-1 py-2.5 flex flex-col items-center gap-1 text-xs font-medium transition-colors"
              style={{ background: tab === t.id ? "#3F4B23" : "transparent", color: tab === t.id ? "#FFF6E0" : "#3F4B23" }}>
              <t.icon className="w-4 h-4" />
              {t.label}
            </button>
          ))}
        </div>

        {/* HOME TAB */}
        {tab === "home" && (
          <div className="px-5 mt-4 pb-8 space-y-2.5">
            {PRAYERS.map((p) => {
              const isNext = nextPrayer && nextPrayer.key === p.key;
              return (
                <div key={p.key} className="flex items-center justify-between rounded-xl px-4 py-3"
                  style={{
                    background: isNext ? "linear-gradient(90deg,#5C6B33,#3F4B23)" : "rgba(255,246,224,0.55)",
                    border: isNext ? "1px solid #E8C766" : "1px solid rgba(74,93,35,0.25)",
                  }}>
                  <div className="flex items-center gap-3">
                    <p.icon className="w-4 h-4" style={{ color: isNext ? "#E8C766" : "#4A5D23" }} />
                    <span className="font-medium" style={{ color: isNext ? "#FFF6E0" : "#2A3318" }}>{p.label}</span>
                  </div>
                  <div className="flex items-center gap-3">
                    <span className="font-semibold amiri text-lg" style={{ color: isNext ? "#FFF6E0" : "#2A3318" }}>{fmtTime(times[p.key])}</span>
                    {p.key !== "sunrise" && (
                      <button onClick={() => setPrayerAlerts((prev) => ({ ...prev, [p.key]: !prev[p.key] }))}>
                        <Bell className="w-4 h-4" style={{ color: prayerAlerts[p.key] ? (isNext ? "#E8C766" : "#4A5D23") : "#B0A98C" }} fill={prayerAlerts[p.key] ? "currentColor" : "none"} />
                      </button>
                    )}
                  </div>
                </div>
              );
            })}

            <button onClick={() => setShowSettings(true)}
              className="w-full mt-3 rounded-xl py-3 flex items-center justify-center gap-2 font-medium"
              style={{ background: "#2A3318", color: "#E8C766" }}>
              <Settings className="w-4 h-4" /> ضبط الموقع والحسابات
            </button>
          </div>
        )}

        {/* QIBLA TAB */}
        {tab === "qibla" && (
          <div className="px-5 mt-6 pb-10 flex flex-col items-center">
            <p className="text-sm mb-4 text-center" style={{ color: "#2A3318" }}>اتجاه القبلة: <strong>{qibla.toFixed(1)}°</strong> من الشمال</p>
            {heading === null && (
              <button onClick={enableCompass} className="mb-6 rounded-xl px-5 py-3 flex items-center gap-2 font-medium"
                style={{ background: "#3F4B23", color: "#FFF6E0" }}>
                <Navigation className="w-4 h-4" /> تفعيل البوصلة
              </button>
