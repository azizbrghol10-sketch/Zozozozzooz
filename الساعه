/* ---------------- Prayer time astronomy helpers (approximate solar-position method) ---------------- */
const dsin = (d) => Math.sin((d * Math.PI) / 180);
const dcos = (d) => Math.cos((d * Math.PI) / 180);
const dtan = (d) => Math.tan((d * Math.PI) / 180);
const darcsin = (x) => (Math.asin(x) * 180) / Math.PI;
const darccos = (x) => (Math.acos(Math.min(1, Math.max(-1, x))) * 180) / Math.PI;
const darctan2 = (y, x) => (Math.atan2(y, x) * 180) / Math.PI;
const darccot = (x) => darctan2(1, x);
const fixAngle = (a) => { a = a - 360 * Math.floor(a / 360); return a < 0 ? a + 360 : a; };
const fixHour = (a) => { a = a - 24 * Math.floor(a / 24); return a < 0 ? a + 24 : a; };

function julianDay(year, month, day) {
  if (month <= 2) { year -= 1; month += 12; }
  const A = Math.floor(year / 100);
  const B = 2 - A + Math.floor(A / 4);
  return Math.floor(365.25 * (year + 4716)) + Math.floor(30.6001 * (month + 1)) + day + B - 1524.5;
}

function sunPosition(jd) {
  const D = jd - 2451545.0;
  const g = fixAngle(357.529 + 0.98560028 * D);
  const q = fixAngle(280.459 + 0.98564736 * D);
  const L = fixAngle(q + 1.915 * dsin(g) + 0.02 * dsin(2 * g));
  const e = 23.439 - 0.00000036 * D;
  const RA = darctan2(dcos(e) * dsin(L), dcos(L)) / 15;
  const eqt = q / 15 - fixHour(RA);
  const decl = darcsin(dsin(e) * dsin(L));
  return { decl, eqt };
}

const METHODS = {
  MWL: { name: "رابطة العالم الإسلامي", fajr: 18, isha: 18 },
  ISNA: { name: "الجمعية الإسلامية لأمريكا الشمالية", fajr: 15, isha: 15 },
  EGYPT: { name: "الهيئة المصرية العامة للمساحة", fajr: 19.5, isha: 17.5 },
  MAKKAH: { name: "أم القرى (مكة)", fajr: 18.5, isha: "90min" },
  KARACHI: { name: "جامعة العلوم الإسلامية كراتشي", fajr: 18, isha: 18 },
};

function computeTimes({ lat, lng, timezone, date, method, asrFactor, offsets }) {
  const jd = julianDay(date.getFullYear(), date.getMonth() + 1, date.getDate());
  const { decl, eqt } = sunPosition(jd - lng / (15 * 24));
  const dhuhr = 12 - eqt - lng / 15 + timezone;

  const hourAngle = (angle) => {
    const num = -dsin(angle) - dsin(lat) * dsin(decl);
    const den = dcos(lat) * dcos(decl);
    if (Math.abs(num / den) > 1) return null;
    return darccos(num / den) / 15;
  };
  const asrHourAngle = () => {
    const altitude = darccot(asrFactor + Math.abs(dtan(lat - decl)));
    const num = dsin(altitude) - dsin(lat) * dsin(decl);
    const den = dcos(lat) * dcos(decl);
    if (Math.abs(num / den) > 1) return null;
    return darccos(num / den) / 15;
  };

  const m = METHODS[method];
  const fajrT = hourAngle(m.fajr);
  const sunriseT = hourAngle(0.833);
  const asrT = asrHourAngle();
  const maghribT = hourAngle(0.833);
  const ishaT = m.isha === "90min" ? null : hourAngle(m.isha);

  const toDate = (h) => {
    if (h === null) return null;
    const d = new Date(date);
    d.setHours(0, 0, 0, 0);
    d.setMinutes(Math.round(h * 60));
    return d;
  };

  const fajr = toDate(fajrT !== null ? dhuhr - fajrT : null);
  const sunrise = toDate(sunriseT !== null ? dhuhr - sunriseT : null);
  const dhuhrD = toDate(dhuhr);
  const asr = toDate(asrT !== null ? dhuhr + asrT : null);
  const maghrib = toDate(maghribT !== null ? dhuhr + maghribT : null);
  const isha = ishaT !== null ? toDate(dhuhr + ishaT) : (maghrib ? new Date(maghrib.getTime() + 90 * 60000) : null);

  const applyOffset = (d, mins) => (d ? new Date(d.getTime() + (mins || 0) * 60000) : null);

  return {
    fajr: applyOffset(fajr, offsets.fajr),
    sunrise: applyOffset(sunrise, offsets.sunrise),
    dhuhr: applyOffset(dhuhrD, offsets.dhuhr),
    asr: applyOffset(asr, offsets.asr),
    maghrib: applyOffset(maghrib, offsets.maghrib),
    isha: applyOffset(isha, offsets.isha),
  };
}

function qiblaBearing(lat, lng) {
  const kLat = 21.4225, kLng = 39.8262;
  const phiK = (kLat * Math.PI) / 180, phi = (lat * Math.PI) / 180;
  const lambdaK = (kLng * Math.PI) / 180, lambda = (lng * Math.PI) / 180;
  const psi = Math.atan2(
    Math.sin(lambdaK - lambda),
    Math.cos(phi) * Math.tan(phiK) - Math.sin(phi) * Math.cos(lambdaK - lambda)
  );
  return (((psi * 180) / Math.PI) + 360) % 360;
}

const fmtTime = (d) => d ? d.toLocaleTimeString("ar-SA", { hour: "2-digit", minute: "2-digit", hour12: true }) : "--:--";

const PRAYERS = [
