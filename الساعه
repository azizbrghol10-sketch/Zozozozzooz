                </div>
              </div>
              <div className="absolute w-3 h-3 rounded-full" style={{ background: "#2A3318" }} />
            </div>
            <p className="text-xs mt-5 text-center max-w-xs" style={{ color: "#4A3E10" }}>
              {heading === null ? "فعّل البوصلة ثم وجّه الجوال بشكل مسطح — السهم يشير إلى الكعبة." : "وجّه السهم بعيدًا عنك ليصبح مؤشر البوصلة نحو القبلة."}
            </p>
          </div>
        )}

        {/* ALARMS TAB */}
        {tab === "alarms" && (
          <div className="px-5 mt-4 pb-10 space-y-4">
            <div className="rounded-xl p-4" style={{ background: "rgba(255,246,224,0.6)", border: "1px solid rgba(74,93,35,0.25)" }}>
              <h3 className="font-semibold mb-3" style={{ color: "#2A3318" }}>إضافة منبه جديد</h3>
              <div className="flex gap-2 mb-2">
                <input type="time" value={newAlarmTime} onChange={(e) => setNewAlarmTime(e.target.value)}
                  className="flex-1 rounded-lg px-3 py-2 text-sm" style={{ border: "1px solid #4A5D23", background: "#FFF6E0" }} />
              </div>
              <input type="text" placeholder="تسمية (مثال: للاستيقاظ)" value={newAlarmLabel} onChange={(e) => setNewAlarmLabel(e.target.value)}
                className="w-full rounded-lg px-3 py-2 text-sm mb-3" style={{ border: "1px solid #4A5D23", background: "#FFF6E0" }} />
              <button onClick={addAlarm} className="w-full rounded-lg py-2.5 flex items-center justify-center gap-2 font-medium"
                style={{ background: "#3F4B23", color: "#FFF6E0" }}>
                <Plus className="w-4 h-4" /> إضافة المنبه
              </button>
            </div>

            {alarms.length > 0 && (
              <div className="space-y-2">
                {alarms.map((a) => (
                  <div key={a.id} className="flex items-center justify-between rounded-xl px-4 py-3"
                    style={{ background: "rgba(255,246,224,0.55)", border: "1px solid rgba(74,93,35,0.25)" }}>
                    <div>
                      <div className="amiri text-xl font-bold" style={{ color: "#2A3318" }}>{a.time}</div>
                      <div className="text-xs" style={{ color: "#4A3E10" }}>{a.label}</div>
                    </div>
                    <div className="flex items-center gap-3">
                      <button onClick={() => toggleAlarm(a.id)}
                        className="w-11 h-6 rounded-full relative transition-colors"
                        style={{ background: a.enabled ? "#4A5D23" : "#C9BFA0" }}>
                        <span className="absolute top-0.5 w-5 h-5 rounded-full bg-white transition-all"
                          style={{ [a.enabled ? "right" : "left"]: "2px" }} />
                      </button>
                      <button onClick={() => removeAlarm(a.id)}><Trash2 className="w-4 h-4" style={{ color: "#8B3A2A" }} /></button>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {/* tone settings */}
            <div className="rounded-xl p-4" style={{ background: "rgba(255,246,224,0.6)", border: "1px solid rgba(74,93,35,0.25)" }}>
              <h3 className="font-semibold mb-3" style={{ color: "#2A3318" }}>نغمة المنبه</h3>
              <ToneSelector tones={tones.filter(t => true)} active={activeAlarmTone} onSelect={setActiveAlarmTone} onPlay={(id) => playTone(id, 2500)} />
              <label className="mt-3 flex items-center gap-2 text-sm cursor-pointer" style={{ color: "#3F4B23" }}>
                <Upload className="w-4 h-4" /> رفع نغمة مخصصة
                <input type="file" accept="audio/*" className="hidden" onChange={(e) => handleFileUpload(e, "alarm")} />
              </label>
            </div>

            <div className="rounded-xl p-4" style={{ background: "rgba(255,246,224,0.6)", border: "1px solid rgba(74,93,35,0.25)" }}>
              <h3 className="font-semibold mb-3" style={{ color: "#2A3318" }}>صوت الأذان (يمكن إضافة صوت شيخ)</h3>
              <ToneSelector tones={tones} active={activeAdhanTone} onSelect={setActiveAdhanTone} onPlay={(id) => playTone(id, 3500)} />
              <label className="mt-3 flex items-center gap-2 text-sm cursor-pointer" style={{ color: "#3F4B23" }}>
                <Upload className="w-4 h-4" /> رفع تسجيل أذان (ملف صوتي)
                <input type="file" accept="audio/*" className="hidden" onChange={(e) => handleFileUpload(e, "adhan")} />
              </label>
              <p className="text-xs mt-2" style={{ color: "#6B5A1E" }}>ملاحظة: الملفات المرفوعة تبقى متاحة خلال هذه الجلسة على هذا الجهاز فقط.</p>
            </div>
          </div>
        )}
      </div>

      {/* Settings modal */}
      {showSettings && (
        <div className="fixed inset-0 z-40 flex items-end md:items-center justify-center" style={{ background: "rgba(0,0,0,0.5)" }}>
          <div className="w-full max-w-md rounded-t-2xl md:rounded-2xl p-5 max-h-[85vh] overflow-y-auto" style={{ background: "#FFF6E0" }}>
            <div className="flex items-center justify-between mb-4">
              <h2 className="font-bold text-lg" style={{ color: "#2A3318" }}>الإعدادات</h2>
              <button onClick={() => setShowSettings(false)}><X className="w-5 h-5" style={{ color: "#2A3318" }} /></button>
            </div>

            <div className="mb-4">
              <label className="text-sm font-medium block mb-1" style={{ color: "#3F4B23" }}>الموقع الجغرافي</label>
              <button onClick={detectLocation} disabled={locating}
                className="w-full mb-2 rounded-lg py-2.5 flex items-center justify-center gap-2 text-sm font-medium"
                style={{ background: "#3F4B23", color: "#FFF6E0" }}>
                {locating ? <RefreshCw className="w-4 h-4 animate-spin" /> : <MapPin className="w-4 h-4" />}
                {locating ? "جاري تحديد الموقع..." : "استخدام موقعي الحالي"}
              </button>
              <div className="flex gap-2">
                <input type="number" step="0.0001" value={location.lat}
                  onChange={(e) => setLocation((p) => ({ ...p, lat: parseFloat(e.target.value) || 0, city: "موقع مخصص" }))}
                  placeholder="خط العرض" className="flex-1 rounded-lg px-3 py-2 text-sm" style={{ border: "1px solid #4A5D23" }} />
                <input type="number" step="0.0001" value={location.lng}
                  onChange={(e) => setLocation((p) => ({ ...p, lng: parseFloat(e.target.value) || 0, city: "موقع مخصص" }))}
                  placeholder="خط الطول" className="flex-1 rounded-lg px-3 py-2 text-sm" style={{ border: "1px solid #4A5D23" }} />
              </div>
              <div className="flex items-center gap-2 mt-2">
                <span className="text-sm" style={{ color: "#3F4B23" }}>فرق التوقيت (UTC):</span>
                <input type="number" step="0.5" value={timezone} onChange={(e) => setTimezone(parseFloat(e.target.value) || 0)}
                  className="w-20 rounded-lg px-2 py-1 text-sm" style={{ border: "1px solid #4A5D23" }} />
              </div>
            </div>

            <div className="mb-4">
              <label className="text-sm font-medium block mb-1" style={{ color: "#3F4B23" }}>طريقة الحساب</label>
              <select value={method} onChange={(e) => setMethod(e.target.value)}
                className="w-full rounded-lg px-3 py-2 text-sm" style={{ border: "1px solid #4A5D23", background: "#fff" }}>
                {Object.entries(METHODS).map(([k, v]) => <option key={k} value={k}>{v.name}</option>)}
              </select>
            </div>

            <div className="mb-4">
              <label className="text-sm font-medium block mb-1" style={{ color: "#3F4B23" }}>مذهب العصر</label>
              <div className="flex gap-2">
                <button onClick={() => setAsrFactor(1)} className="flex-1 rounded-lg py-2 text-sm font-medium"
                  style={{ background: asrFactor === 1 ? "#3F4B23" : "#EAE0C0", color: asrFactor === 1 ? "#FFF6E0" : "#2A3318" }}>الشافعي/جمهور الفقهاء</button>
                <button onClick={() => setAsrFactor(2)} className="flex-1 rounded-lg py-2 text-sm font-medium"
                  style={{ background: asrFactor === 2 ? "#3F4B23" : "#EAE0C0", color: asrFactor === 2 ? "#FFF6E0" : "#2A3318" }}>الحنفي</button>
              </div>
            </div>

            <div className="mb-2">
              <label className="text-sm font-medium block mb-2" style={{ color: "#3F4B23" }}>تعديل يدوي للأوقات (دقائق)</label>
              <div className="space-y-2">
                {PRAYERS.map((p) => (
                  <div key={p.key} className="flex items-center justify-between">
                    <span className="text-sm" style={{ color: "#2A3318" }}>{p.label}</span>
                    <div className="flex items-center gap-2">
                      <button onClick={() => setOffsets((o) => ({ ...o, [p.key]: (o[p.key] || 0) - 1 }))}
                        className="w-7 h-7 rounded-full text-sm font-bold" style={{ background: "#EAE0C0", color: "#2A3318" }}>−</button>
                      <span className="w-8 text-center text-sm" style={{ color: "#2A3318" }}>{offsets[p.key] || 0}</span>
                      <button onClick={() => setOffsets((o) => ({ ...o, [p.key]: (o[p.key] || 0) + 1 }))}
                        className="w-7 h-7 rounded-full text-sm font-bold" style={{ background: "#EAE0C0", color: "#2A3318" }}>+</button>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <button onClick={() => setShowSettings(false)} className="w-full mt-4 rounded-lg py-2.5 font-medium flex items-center justify-center gap-2"
              style={{ background: "#3F4B23", color: "#FFF6E0" }}>
              <Check className="w-4 h-4" /> تم
            </button>
          </div>
        </div>
      )}

      {/* Ringing overlay */}
      {ringing && (
        <div className="fixed inset-0 z-50 flex flex-col items-center justify-center px-6" style={{ background: "rgba(42,51,24,0.95)" }}>
          <Bell className="w-16 h-16 mb-4 animate-bounce" style={{ color: "#E8C766" }} />
          <p className="amiri text-2xl font-bold text-center mb-1" style={{ color: "#FFF6E0" }}>{ringing.label}</p>
          <p className="text-sm mb-8" style={{ color: "#E8C766" }}>{now.toLocaleTimeString("ar-SA", { hour: "2-digit", minute: "2-digit", hour12: true })}</p>
          <button onClick={stopRinging} className="rounded-full px-10 py-3 font-bold flex items-center gap-2"
            style={{ background: "#E8C766", color: "#2A3318" }}>
            <Square className="w-4 h-4" /> إيقاف
          </button>
        </div>
      )}
    </div>
  );
}

function ToneSelector({ tones, active, onSelect, onPlay }) {
  return (
    <div className="space-y-1.5">
      {tones.map((t) => (
        <div key={t.id} onClick={() => onSelect(t.id)}
          className="flex items-center justify-between rounded-lg px-3 py-2 cursor-pointer"
          style={{ background: active === t.id ? "#E8C766" : "#F3ECD6", border: active === t.id ? "1px solid #3F4B23" : "1px solid transparent" }}>
          <div className="flex items-center gap-2">
            <div className="w-4 h-4 rounded-full flex items-center justify-center" style={{ border: "2px solid #3F4B23", background: active === t.id ? "#3F4B23" : "transparent" }} />
            <span className="text-sm" style={{ color: "#2A3318" }}>{t.name}{t.type === "custom" ? " (مخصص)" : ""}</span>
          </div>
          <button onClick={(e) => { e.stopPropagation(); onPlay(t.id); }}>
            <Play className="w-4 h-4" style={{ color: "#3F4B23" }} />
          </button>
        </div>
      ))}
    </div>
  );
}
